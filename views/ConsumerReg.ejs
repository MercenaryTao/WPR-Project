<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="page">
    <div class="section">
        <h1 class="section-title">Consumer Registration</h1>
        <form action="/ConsumerReg" method="POST" class="form">
            <fieldset class="form-fieldset">
                <input type="text" name="username" id="username" placeholder="Username" class="form-input" required>
                <input type="email" name="email" id="email" placeholder="Email" class="form-input" required>
                <input type="password" name="password" id="password" placeholder="Password" class="form-input" required>
                <% if (error) { %>
                    <p class="alert-error"><%= error %></p>
                <% } %>
                <button type="submit" class="btn btn-primary">Sign Up</button>
            </fieldset>
        </form>
    </div>
</body>
</html>