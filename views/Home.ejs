<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="page">
  <%- include('partials/header') %>
  <div class="section">
    <h1 class="section-title">Available Events</h1>

    <div>
      <h2 class="section-subtitle">Search & Filter Events</h2>
      <form action="/Home" method="GET" class="form">
        <div>
          <label class="form-label" for="search">Search</label>
          <input id="search" name="search" type="search" class="form-input" value="<%= filters.search %>" placeholder="Search event name" />
        </div>
        <div>
          <label class="form-label" for="category">Category</label>
          <select id="category" name="category" class="form-input">
            <option value="all" <%= filters.category === "all" ? "selected" : "" %>>All</option>
            <% categories.forEach(category => { %>
              <option value="<%= category %>" <%= filters.category === category ? "selected" : "" %>><%= category %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="form-label" for="date">Date</label>
          <input id="date" name="date" type="date" class="form-input" value="<%= filters.date %>" />
        </div>
        <div>
          <label class="form-label" for="availability">Availability</label>
          <select id="availability" name="availability" class="form-input">
            <option value="all" <%= filters.availability === "all" ? "selected" : "" %>>All</option>
            <option value="available" <%= filters.availability === "available" ? "selected" : "" %>>Available</option>
            <option value="soldout" <%= filters.availability === "soldout" ? "selected" : "" %>>Sold Out</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary">Apply</button>
      </form>
    </div>

    <div class="list">
      <% if (!events.length) { %>
        <p>No events match your search or filters.</p>
      <% } else { %>
        <% events.forEach(event => { %>
          <div class="event-card">
            <h2 class="event-title"><%= event.event %></h2>
            <p class="event-price">Price: $<%= event.price %></p>
            <p>Category: <%= event.category || "General" %></p>
            <p>Date: <%= event.date ? event.date.toLocaleDateString() : "TBD" %></p>
            <p class="event-qty">Tickets left: <%= event.quantity %></p>
            <p>Availability: <%= event.quantity > 0 ? "Available" : "Sold Out" %></p>
            <a href="/BookEvent/<%= event._id %>" class="btn btn-success">Book Event</a>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>
  </div>
</body>
</html>