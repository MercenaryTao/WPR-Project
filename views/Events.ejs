<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Events</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="page">
  <%- include('partials/header') %>
  <div class="section">
    <h1 class="section-title">Events</h1>
    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>
    <% if (user && user.role === 'admin') { %>
      <form action="/Events" method="POST" class="form">
        <div class="form-fieldset">
          <input class="form-input" type="text" name="event" id="eventInput" placeholder="Event Name" required>
          <input class="form-input" type="text" name="category" id="categoryInput" placeholder="Category" required>
          <input class="form-input" type="date" name="date" id="dateInput" required>
          <input class="form-input" type="number" name="price" id="priceInput" placeholder="Price" required>
          <input class="form-input" type="number" name="quantity" id="qtyInput" placeholder="Quantity" required>
          <button class="btn btn-primary" type="submit">Add Event</button>
        </div>
      </form>
    <% } else { %>
      <p>Only admins can add events. <a href="/AdminLogin">Admin login</a></p>
    <% } %>

    <div class="list">
      <% events.forEach(event => { %>
        <div class="event-card">
          <h4 class="event-title"><%= event.event %></h4>
          <p class="event-price">Price: $<%= event.price %></p>
          <p>Category: <%= event.category || "General" %></p>
          <p>Date: <%= event.date ? event.date.toLocaleDateString() : "TBD" %></p>
          <p class="event-qty">Quantity: <%= event.quantity %></p>
          <a href="/EditEvent/<%= event._id %>" class="btn btn-primary">Edit</a>
          <a href="/DeleteEvent/<%= event._id %>" class="btn btn-danger">Delete</a>
        </div>
      <% }); %>
    </div>
  </div>

  <script src="/js/eventActions.js"></script>
</body>
</html>