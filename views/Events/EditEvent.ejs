<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Event</title>
</head>
<body>
  <div class="container">
    <h1>Edit Event</h1>
    <form id="updateEventForm">
      <label>Event</label>
      <input type="text" id="eventInput" value="<%= event.event %>" required>
      <label>Price</label>
      <input type="number" id="priceInput" value="<%= event.price %>" required>
      <label>Quantity</label>
      <input type="number" id="quantityInput" value="<%= event.quantity %>" required>
      <button type="button" onclick="updateEvent('<%= event._id %>')">Update Event</button>
      <a href="/Events">Cancel</a>
    </form>
  </div>

  <script src="/js/eventActions.js"></script>
</body>
</html>