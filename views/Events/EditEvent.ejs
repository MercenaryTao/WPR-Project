<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Event</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <h1>Edit Event</h1>
    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>
    <form id="updateEventForm" class="form">
      <label>Event</label>
      <input class="form-input" type="text" id="eventInput" value="<%= event.event %>" required>
      <label>Category</label>
      <input class="form-input" type="text" id="categoryInput" value="<%= event.category || '' %>" required>
      <label>Date</label>
      <input class="form-input" type="date" id="dateInput" value="<%= event.date ? event.date.toISOString().split('T')[0] : '' %>" required>
      <label>Price</label>
      <input class="form-input" type="number" id="priceInput" value="<%= event.price %>" required>
      <label>Quantity</label>
      <input class="form-input" type="number" id="quantityInput" value="<%= event.quantity %>" required>
      <button class="btn btn-primary" type="button" onclick="updateEvent('<%= event._id %>')">Update Event</button>
      <a class="btn btn-warning" href="/Events">Cancel</a>
    </form>
  </div>

  <script src="/js/eventActions.js"></script>
</body>
</html>