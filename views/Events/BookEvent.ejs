<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="page">
    <div class="section">
        <h1 class="section-title">Book Event</h1>
        <form action="/BookEvent/<%= event._id %>" method="POST" class="form">
            <fieldset class="form-fieldset">
                <h2 class="event-title"><%= event.event %></h2>
                <p class="event-price">Price: $<%= event.price %></p>
                <p class="event-qty">Available Quantity: <%= event.quantity %></p>
            </fieldset>
            <fieldset class="form-fieldset">
                <label for="qty">Quantity to Book:</label>
                <input type="number" name="qty" id="qty" placeholder="Quantity" class="form-input" required>
                <p id="total" class="event-price" style="margin-top: 15px;"></p>
                <button type="submit" class="btn btn-primary">Book Now</button>
            </fieldset>
        </form>
    </div>

    <script>
        const qtyInput = document.getElementById("qty");
        const total = document.getElementById("total");
        const price = <%= event.price %>;

        qtyInput.addEventListener("input", () => {
            const qty = Number(qtyInput.value);
            total.textContent = "Total Cost: $" + (qty * price);
        });
    </script>
</body>
</html>