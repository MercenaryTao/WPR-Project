<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Delete Event</title>
</head>
<body>
  <div class="container">
    <h1>Delete Event</h1>
    <p>Are you sure you want to delete the event:</p>
    <h2><%= event.event %></h2>
    <p>Price: $<%= event.price %></p>
    <p>Quantity: <%= event.quantity %></p>
    <button type="button" onclick="deleteEvent('<%= event._id %>')">Confirm Delete</button>
    <a href="/Events">Cancel</a>
  </div>

  <script src="/js/eventActions.js"></script>
</body>
</html>