<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="page">
    <%- include('partials/header') %>
    <div class="section">
        <h1 class="section-title">Booking & Dashboard</h1>
        <div class="list">
           <% events.forEach(event => { %>
            <div class="event-card">
                <h2 class="event-title"><%= event.event %></h2>
                <p class="event-price">Price: $<%= event.price %></p>
                <p class="event-qty">Quantity: <%= event.quantity %></p>
                <a href="/Events/BookEvent/<%= event._id %>" class="btn btn-success">Book Event</a>
            </div>
        <% }); %>
        </div>
    </div>